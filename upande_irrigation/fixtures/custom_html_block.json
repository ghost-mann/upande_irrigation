  "doctype": "Custom HTML Block",
  "html": "<style>\n.irrnav { font-family: var(--font-stack); padding: 0; display: flex; flex-direction: column; gap: 16px; }\n.irrnav-banner { border-radius: 10px; overflow: hidden; }\n.irrnav-banner-link { display: flex; align-items: center; gap: 14px; padding: 14px 20px; background: linear-gradient(135deg, #0c4a6e, #0891b2); color: white; text-decoration: none; transition: opacity 0.15s; }\n.irrnav-banner-link:hover { opacity: 0.93; text-decoration: none; }\n.irrnav-banner-icon { width: 40px; height: 40px; border-radius: 8px; background: rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }\n.irrnav-banner-text { display: flex; flex-direction: column; gap: 2px; }\n.irrnav-banner-title { font-size: 0.9375rem; font-weight: 700; color: white; }\n.irrnav-banner-sub { font-size: 0.75rem; opacity: 0.85; color: white; }\n.irrnav-banner-arrow { margin-left: auto; font-size: 1.25rem; color: white; }\n.irrnav-shortcuts { display: flex; gap: 10px; flex-wrap: wrap; }\n.irrnav-shortcut { display: inline-flex; align-items: center; gap: 8px; padding: 9px 16px; border-radius: 8px; font-size: 0.8125rem; font-weight: 600; text-decoration: none; transition: opacity 0.15s, transform 0.1s; border: none; cursor: pointer; }\n.irrnav-shortcut:hover { opacity: 0.88; transform: translateY(-1px); text-decoration: none; }\n.irrnav-shortcut-icon { display: flex; align-items: center; justify-content: center; width: 22px; height: 22px; border-radius: 5px; background: rgba(255,255,255,0.25); flex-shrink: 0; }\n.irrnav-shortcut-cyan  { background: #0891b2; color: white; }\n.irrnav-shortcut-blue  { background: #1d4ed8; color: white; }\n.irrnav-shortcut-teal  { background: #0f766e; color: white; }\n.irrnav-shortcut-slate { background: #475569; color: white; }\n.irrnav-row { display: grid; gap: 16px; }\n.irrnav-row-3 { grid-template-columns: repeat(3, 1fr); }\n.irrnav-row-2 { grid-template-columns: repeat(2, 1fr); }\n.irrnav-card { background: var(--fg-color); border: 1px solid var(--border-color); border-radius: 12px; overflow: hidden; }\n.irrnav-card-header { display: flex; align-items: center; gap: 10px; padding: 14px 16px 12px; border-bottom: 1px solid var(--border-color); }\n.irrnav-card-icon { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }\n.irrnav-card-header span { font-size: 0.875rem; font-weight: 600; color: var(--text-color); }\n.irrnav-blue  .irrnav-card-icon { background: rgba(29,78,216,0.10);  color: #1d4ed8; }\n.irrnav-cyan  .irrnav-card-icon { background: rgba(8,145,178,0.10);   color: #0891b2; }\n.irrnav-teal  .irrnav-card-icon { background: rgba(15,118,110,0.10);  color: #0f766e; }\n.irrnav-green .irrnav-card-icon { background: rgba(22,163,74,0.10);   color: #16a34a; }\n.irrnav-amber .irrnav-card-icon { background: rgba(245,158,11,0.12);  color: #f59e0b; }\n.irrnav-links { display: flex; flex-direction: column; padding: 6px; }\n.irrnav-link { display: flex; align-items: center; gap: 8px; padding: 8px 10px; border-radius: 7px; text-decoration: none; font-size: 0.8125rem; font-weight: 500; color: var(--text-muted); transition: background 0.15s, color 0.15s; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n.irrnav-link:hover { background: var(--control-bg, #f1f5f9); color: var(--text-color); text-decoration: none; }\n.irrnav-link svg { flex-shrink: 0; opacity: 0.6; }\n.irrnav-link:hover svg { opacity: 1; }\n.irrnav-link-primary { color: #0891b2; font-weight: 600; }\n.irrnav-link-primary svg { color: #0891b2; opacity: 1; }\n.irrnav-link-primary:hover { background: rgba(8,145,178,0.08); color: #0891b2; }\n@media (max-width: 900px) { .irrnav-row-3, .irrnav-row-2 { grid-template-columns: 1fr; } .irrnav-shortcuts { flex-direction: column; } }\n</style>\n\n<div class=\"irrnav\">\n\n  <!-- Banner -->\n  <div class=\"irrnav-banner\">\n    <a href=\"/meniscus\" class=\"irrnav-banner-link\">\n      <span class=\"irrnav-banner-icon\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" width=\"22\" height=\"22\"><path d=\"M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10\"/><path d=\"M12 2c0 5.52-4 10-4 10s4 4.48 4 10\"/><path d=\"M2 12h20\"/></svg>\n      </span>\n      <div class=\"irrnav-banner-text\">\n        <div class=\"irrnav-banner-title\">Open Irrigation Dashboard</div>\n        <div class=\"irrnav-banner-sub\">View blocks, readings, soil tension &amp; water usage &mdash; all in one place</div>\n      </div>\n      <span class=\"irrnav-banner-arrow\">&rarr;</span>\n    </a>\n  </div>\n\n  <!-- Shortcut pills -->\n  <div class=\"irrnav-shortcuts\">\n    <a href=\"/irrigation-dashboard\" class=\"irrnav-shortcut irrnav-shortcut-cyan\">\n      <span class=\"irrnav-shortcut-icon\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" width=\"15\" height=\"15\"><line x1=\"18\" y1=\"20\" x2=\"18\" y2=\"10\"/><line x1=\"12\" y1=\"20\" x2=\"12\" y2=\"4\"/><line x1=\"6\" y1=\"20\" x2=\"6\" y2=\"14\"/></svg>\n      </span>\n      Irrigation Overview\n    </a>\n    <a href=\"/app/irrigation-block\" class=\"irrnav-shortcut irrnav-shortcut-blue\">\n      <span class=\"irrnav-shortcut-icon\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" width=\"15\" height=\"15\"><rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\"/><path d=\"M3 9h18M9 21V9\"/></svg>\n      </span>\n      Irrigation Blocks\n    </a>\n    <a href=\"/app/irrigation-reading\" class=\"irrnav-shortcut irrnav-shortcut-teal\">\n      <span class=\"irrnav-shortcut-icon\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" width=\"15\" height=\"15\"><polyline points=\"22 12 18 12 15 21 9 3 6 12 2 12\"/></svg>\n      </span>\n      Daily Readings\n    </a>\n    <a href=\"/app/work-order?custom_type=Irrigation+Schedule\" class=\"irrnav-shortcut irrnav-shortcut-slate\">\n      <span class=\"irrnav-shortcut-icon\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" width=\"15\" height=\"15\"><rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\"/><line x1=\"16\" y1=\"2\" x2=\"16\" y2=\"6\"/><line x1=\"8\" y1=\"2\" x2=\"8\" y2=\"6\"/><line x1=\"3\" y1=\"10\" x2=\"21\" y2=\"10\"/></svg>\n      </span>\n      Schedule\n    </a>\n<a href=\"/app/work-order?custom_type=Irrigation+Schedule\" class=\"irrnav-shortcut irrnav-shortcut-water\">\n  <span class=\"irrnav-shortcut-icon\">\n    <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" width=\"15\" height=\"15\"><path d=\"M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z\"/></svg>\n  </span>\n  Water Management\n</a>\n  </div>\n\n  <!-- Row 1: 3 cards -->\n  <div class=\"irrnav-row irrnav-row-3\">\n\n    <!-- Irrigation Blocks -->\n    <div class=\"irrnav-card\">\n      <div class=\"irrnav-card-header irrnav-blue\">\n        <div class=\"irrnav-card-icon\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" width=\"18\" height=\"18\"><rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\"/><path d=\"M3 9h18M9 21V9\"/></svg>\n        </div>\n        <span>Irrigation Blocks</span>\n      </div>\n      <div class=\"irrnav-links\">\n        <a href=\"/app/irrigation-block/new-irrigation-block-1\" class=\"irrnav-link irrnav-link-primary\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" width=\"14\" height=\"14\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg>New Irrigation Block\n        </a>\n        <a href=\"/app/irrigation-block\" class=\"irrnav-link\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" width=\"14\" height=\"14\"><path d=\"M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z\"/><polyline points=\"14 2 14 8 20 8\"/></svg>All Blocks\n        </a>\n        <a href=\"/app/irrigation-block?is_active=1\" class=\"irrnav-link\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" width=\"14\" height=\"14\"><path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\"/><polyline points=\"22 4 12 14.01 9 11.01\"/></svg>Active Blocks\n        </a>\n      </div>\n    </div>\n\n    <!-- Daily Readings -->\n    <div class=\"irrnav-card\">\n      <div class=\"irrnav-card-header irrnav-cyan\">\n        <div class=\"irrnav-card-icon\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" width=\"18\" height=\"18\"><polyline points=\"22 12 18 12 15 21 9 3 6 12 2 12\"/></svg>\n        </div>\n        <span>Daily Readings</span>\n      </div>\n      <div class=\"irrnav-links\">\n        <a href=\"/app/irrigation-reading/new-irrigation-reading-1\" class=\"irrnav-link irrnav-link-primary\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" width=\"14\" height=\"14\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg>New Reading\n        </a>\n        <a href=\"/app/irrigation-reading\" class=\"irrnav-link\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" width=\"14\" height=\"14\"><path d=\"M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z\"/><polyline points=\"14 2 14 8 20 8\"/></svg>All Readings\n        </a>\n        <a href=\"/app/irrigation-reading?docstatus=1\" class=\"irrnav-link\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" width=\"14\" height=\"14\"><path d=\"M9 11l3 3L22 4\"/><path d=\"M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11\"/></svg>Submitted Readings\n        </a>\n        <a href=\"/app/query-report/Irrigation+Reading+Summary\" class=\"irrnav-link\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" width=\"14\" height=\"14\"><line x1=\"18\" y1=\"20\" x2=\"18\" y2=\"10\"/><line x1=\"12\" y1=\"20\" x2=\"12\" y2=\"4\"/><line x1=\"6\" y1=\"20\" x2=\"6\" y2=\"14\"/></svg>Reading Summary Report\n        </a>\n      </div>\n    </div>\n\n    <!-- Irrometer & Soil -->\n    <div class=\"irrnav-card\">\n      <div class=\"irrnav-card-header irrnav-teal\">\n        <div class=\"irrnav-card-icon\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" width=\"18\" height=\"18\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>\n        </div>\n        <span>Irrometer &amp; Soil</span>\n      </div>\n      <div class=\"irrnav-links\">\n        <a href=\"/app/irrigation-reading?tab=irrometer_reading\" class=\"irrnav-link\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" width=\"14\" height=\"14\"><circle cx=\"12\" cy=\"12\" r=\"3\"/><path d=\"M12 2v3M12 19v3M2 12h3M19 12h3\"/></svg>Irrometer Readings\n        </a>\n        <a href=\"/app/irrigation-block?soil_type=Sandy\" class=\"irrnav-link\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" width=\"14\" height=\"14\"><path d=\"M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z\"/></svg>Sandy Soil Blocks\n        </a>\n        <a href=\"/app/irrigation-block?soil_type=Clay\" class=\"irrnav-link\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" width=\"14\" height=\"14\"><path d=\"M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z\"/></svg>Clay Soil Blocks\n        </a>\n      </div>\n    </div>\n\n  </div>\n\n  <!-- Row 2: 2 cards -->\n  <div class=\"irrnav-row irrnav-row-1\">\n\n    <!-- Scheduling -->\n    <div class=\"irrnav-card\">\n      <div class=\"irrnav-card-header irrnav-green\">\n        <div class=\"irrnav-card-icon\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" width=\"18\" height=\"18\"><rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\"/><line x1=\"16\" y1=\"2\" x2=\"16\" y2=\"6\"/><line x1=\"8\" y1=\"2\" x2=\"8\" y2=\"6\"/><line x1=\"3\" y1=\"10\" x2=\"21\" y2=\"10\"/></svg>\n        </div>\n        <span>Irrigation Scheduling</span>\n      </div>\n      <div class=\"irrnav-links\">\n        <a href=\"/app/work-order/new-work-order-1?custom_type=Irrigation+Schedule\" class=\"irrnav-link irrnav-link-primary\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" width=\"14\" height=\"14\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg>New Schedule\n        </a>\n        <a href=\"/app/work-order?custom_type=Irrigation+Schedule\" class=\"irrnav-link\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" width=\"14\" height=\"14\"><path d=\"M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z\"/><polyline points=\"14 2 14 8 20 8\"/></svg>All Schedules\n        </a>\n        <a href=\"/app/work-order?custom_type=Valve+Maintenance\" class=\"irrnav-link\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" width=\"14\" height=\"14\"><circle cx=\"12\" cy=\"12\" r=\"3\"/><path d=\"M12 2v3M12 19v3M2 12h3M19 12h3\"/></svg>Valve Maintenance\n        </a>\n      </div>\n    </div>\n\n  </div>\n\n</div>",
