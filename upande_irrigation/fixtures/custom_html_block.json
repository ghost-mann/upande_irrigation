  "style": ".irrnav { font-family: var(--font-stack); padding: 0; display: flex; flex-direction: column; gap: 16px; }\n.irrnav-banner { border-radius: 10px; overflow: hidden; }\n.irrnav-banner-link { display: flex; align-items: center; gap: 14px; padding: 14px 20px; background: linear-gradient(135deg, #0c4a6e, #0891b2); color: white; text-decoration: none; transition: opacity 0.15s; }\n.irrnav-banner-link:hover { opacity: 0.93; text-decoration: none; }\n.irrnav-banner-icon { width: 40px; height: 40px; border-radius: 8px; background: rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }\n.irrnav-banner-text { display: flex; flex-direction: column; gap: 2px; }\n.irrnav-banner-title { font-size: 0.9375rem; font-weight: 700; color: white; }\n.irrnav-banner-sub { font-size: 0.75rem; opacity: 0.85; color: white; }\n.irrnav-banner-arrow { margin-left: auto; font-size: 1.25rem; color: white; }\n.irrnav-shortcuts { display: flex; gap: 10px; flex-wrap: wrap; }\n.irrnav-shortcut { display: inline-flex; align-items: center; gap: 8px; padding: 9px 16px; border-radius: 8px; font-size: 0.8125rem; font-weight: 600; text-decoration: none; transition: opacity 0.15s, transform 0.1s; border: none; cursor: pointer; }\n.irrnav-shortcut:hover { opacity: 0.88; transform: translateY(-1px); text-decoration: none; }\n.irrnav-shortcut-icon { display: flex; align-items: center; justify-content: center; width: 22px; height: 22px; border-radius: 5px; background: rgba(255,255,255,0.25); flex-shrink: 0; }\n.irrnav-shortcut-cyan  { background: #0891b2; color: white; }\n.irrnav-shortcut-blue  { background: #1d4ed8; color: white; }\n.irrnav-shortcut-teal  { background: #0f766e; color: white; }\n.irrnav-shortcut-slate { background: #475569; color: white; }\n.irrnav-shortcut-water { background: #0284c7; color: white; }\n.irrnav-row { display: grid; gap: 16px; }\n.irrnav-row-1 { grid-template-columns: 1fr; }\n.irrnav-row-3 { grid-template-columns: repeat(3